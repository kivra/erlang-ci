{erl_opts, [debug_info]}.

{deps, []}.

{project_plugins, [
    erlfmt,
    rebar3_ex_doc,
    {rebar3_audit, {git, "https://github.com/Taure/rebar3_audit.git", {tag, "v0.2.2"}}},
    rebar3_sbom
]}.

{erlfmt, [write]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    deprecated_function_calls,
    deprecated_functions
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {proglang, erlang},
    {main, <<"fixture">>},
    {source_url, <<"https://github.com/Taure/erlang-ci">>}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.
